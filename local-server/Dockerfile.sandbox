# ============================================
# DMLA Python Sandbox Image (GPU Version)
# 支持 CUDA 13.0 的 Python 执行环境
# PyTorch cu130 wheel 使用基础镜像的 CUDA 13.0 运行时
# vLLM 通过 pip 安装 nvidia-*-13.3 包提供 flashinfer JIT 所需 CUDA 13.3 工具链
# 镜像名称: dmla-sandbox:gpu
#
# 构建命令: docker build -t dmla-sandbox:gpu . -f local-server/Dockerfile.sandbox
#
# CUDA 兼容性诊断:
#   docker run --rm --gpus all dmla-sandbox:gpu python3 /workspace/cuda_compat_check.py
#
# 支持的 GPU:
#   - RTX 30 系列 (Ampere, sm_86)
#   - RTX 40 系列 (Ada Lovelace, sm_89)
#   - H100/H200 (Hopper, sm_90)
# ============================================

FROM nvidia/cuda:13.0.0-cudnn-devel-ubuntu22.04

# 设置环境变量
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV DMLA_CUDA_COMPAT=unknown
ENV PYTHONPATH=/workspace
# vLLM flashinfer JIT 编译需要 CUDA 工具链
# 使用基础镜像自带的 CUDA 13.0（/usr/local/cuda），与 flashinfer CCCL 头文件兼容
# pip 安装的 nvidia-cu13 包（13.3 版本）与 flashinfer 的 CCCL 存在版本不兼容
ENV CUDA_HOME=/usr/local/cuda
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

# 替换为阿里云镜像源
RUN sed -i 's|http://archive.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list \
    && sed -i 's|http://security.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list \
    && apt-get update && apt-get install -y \
    software-properties-common \
    curl \
    fonts-wqy-microhei \
    fonts-noto-cjk \
    # 添加重试逻辑应对 Launchpad PPA 服务器超时（最多重试 5 次，每次等待 10 秒）
    && for i in 1 2 3 4 5; do \
        if add-apt-repository ppa:deadsnakes/ppa; then \
            echo "PPA added successfully on attempt $i"; \
            break; \
        else \
            echo "Attempt $i failed, waiting 10 seconds..."; \
            sleep 10; \
        fi; \
    done \
    && apt-get update && apt-get install -y \
    python3.11 \
    python3.11-venv \
    python3.11-dev \
    python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3 \
    && ln -sf /usr/bin/python3 /usr/bin/python

# 升级 pip - 使用清华 PyPI 镜像
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel -i https://pypi.tuna.tsinghua.edu.cn/simple

# 安装科学计算库 - 使用清华镜像
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    numpy \
    pandas \
    matplotlib \
    scipy \
    scikit-learn \
    requests \
    pillow \
    opencv-python-headless \
    ipykernel \
    jupyter_client \
    lmdb

# 安装 PyTorch (GPU 版本，CUDA 13.0，PyPI 默认)
# PyTorch 2.11+ 在 PyPI 上默认为 CUDA 13.0，无需 --index-url
RUN pip install --no-cache-dir \
    torch torchvision torchaudio

# 安装 NVIDIA DALI（GPU 数据加载库，CUDA 13.x 版本）
RUN pip install --no-cache-dir nvidia-dali-cuda130

# 安装 HuggingFace Transformers 生态（LLM 预训练实验所需）
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
    transformers \
    tokenizers \
    datasets \
    ipywidgets \
    accelerate \
    bitsandbytes

# 安装 vLLM 推理框架（PagedAttention、Continuous Batching）
# flashinfer JIT 编译使用 CUDA_HOME 指向的 nvcc，需与 CCCL 头文件版本匹配
RUN pip install --no-cache-dir vllm

# 复制执行器和诊断脚本
COPY local-server/src/kernel_runner.py /workspace/kernel_runner.py
COPY local-server/src/cuda_compat_check.py /workspace/cuda_compat_check.py
COPY local-server/src/dmla_progress.py /workspace/dmla_progress.py

# 复制共享模块到 /workspace/shared（与 PYTHONPATH=/workspace 配合）
COPY local-server/shared /workspace/shared

# 创建数据目录结构
RUN mkdir -p /data/datasets \
             /data/datasets/custom \
             /data/models \
             /data/models/alexnet/checkpoints \
             /data/models/alexnet/final \
             /data/models/vgg \
             /data/models/resnet \
             /data/models/gan \
             /data/models/llm \
             /data/models/minimind/pretrain \
             /data/models/minimind/sft \
             /data/models/pretrained \
             /data/datasets/minimind-pretrain \
             /data/outputs \
             /data/outputs/training_logs \
             /data/outputs/visualizations \
             /data/outputs/exports \
             /data/cache \
             /data/cache/downloads \
             /data/cache/preprocessing \
             /data/cache/torch_hub

# 设置环境变量
ENV TORCH_HOME=/data/cache/torch_hub

# 配置 matplotlib 中文字体支持（包括 sans-serif 和 monospace）
RUN mkdir -p /root/.config/matplotlib && \
    printf "font.family: sans-serif\nfont.sans-serif: WenQuanYi Micro Hei, WenQuanYi Zen Hei, DejaVu Sans\nfont.monospace: WenQuanYi Micro Hei Mono, WenQuanYi Zen Hei Mono, DejaVu Sans Mono\naxes.unicode_minus: False\n" > /root/.config/matplotlib/matplotlibrc && \
    rm -rf /root/.cache/matplotlib

# 默认命令 - 运行 CUDA 兼容性检查
# 实际代码执行时会被 sandbox.js 的 Cmd 参数覆盖
CMD ["python3", "/workspace/cuda_compat_check.py"]